# Claude (Anthropic) — optional. Without it, /api/analyze-room and /api/recommend
# fall back to deterministic local logic so the UI never breaks.
ANTHROPIC_API_KEY=

# Jina Reader — optional. Without it, /api/fetch-dimensions fetches the page directly.
JINA_API_KEY=

# Base URL of the FastAPI layout save/share API (backend/).
NEXT_PUBLIC_LAYOUT_API_BASE=http://localhost:8000
